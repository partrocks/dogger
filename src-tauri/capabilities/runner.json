{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "runner",
  "description": "Capability for the per-task runner windows opened from the tray menu",
  "windows": ["runner-*"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-close"
  ]
}
